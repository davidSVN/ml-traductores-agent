# ============================================
# ML TRADUCTORES AGENT — Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env al repositorio.

# --- Base de Datos ---
DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/ml_traductores

# --- Anthropic (LLM principal) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- LangSmith (Observabilidad) ---
LANGSMITH_API_KEY=lsv2_pt_xxxxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ml-traductores-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- WhatsApp Business API (Meta) ---
WHATSAPP_TOKEN=EAAxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_VERIFY_TOKEN=mi_token_de_verificacion_secreto
WHATSAPP_API_VERSION=v21.0

# --- AWS S3 (para PDFs generados) ---
AWS_ACCESS_KEY_ID=AKIAxxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_S3_BUCKET=ml-traductores-cotizaciones
AWS_REGION=us-east-1

# --- Servidor ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
