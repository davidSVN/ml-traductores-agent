# ============================================
# ML TRADUCTORES AGENT — Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env al repositorio.

# --- Base de Datos (AWS RDS PostgreSQL) ---
DB_HOST=tu-instancia.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ml_traductores
DB_USER=usuario
DB_PASSWORD=password

# --- Anthropic (LLM principal) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- LangSmith (Observabilidad) ---
LANGSMITH_API_KEY=lsv2_pt_xxxxx
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=tracer-ml-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Meta / WhatsApp Business API ---
META_ACCESS_TOKEN=EAAxxxxxxx
META_PHONE_NUMBER_ID=123456789
META_VERIFY_TOKEN=mi_token_de_verificacion_secreto
META_CLIENT_ID=xxxxxxx
META_CLIENT_SECRET=xxxxxxx
META_WABA_ID=xxxxxxx
META_API_VERSION=v21.0

# --- AWS S3 (para PDFs generados) ---
AWS_ACCESS_KEY_ID=AKIAxxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_S3_BUCKET=ml-traductores-cotizaciones
AWS_REGION=us-east-1

# --- Servidor ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
